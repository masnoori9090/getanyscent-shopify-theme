{%- style -%}
  #shopify-section-{{ section.id }} .instagram-feed {
    padding: 8rem 0;
  }

  #shopify-section-{{ section.id }} .instagram-feed__header {
    margin-bottom: 2.4rem;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .instagram-feed__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  #shopify-section-{{ section.id }} .instagram-feed__item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .instagram-feed__item img,
  #shopify-section-{{ section.id }} .instagram-feed__item .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .instagram-feed__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(19, 38, 22, 0.76);
    color: #f5f2ed;
    letter-spacing: 0.18em;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .instagram-feed__item:hover .instagram-feed__overlay {
    opacity: 1;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .instagram-feed__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

<section class="instagram-feed reveal">
  <div class="page-width">
    <div class="instagram-feed__header">
      <h2 class="h1">{{ section.settings.heading }}</h2>
    </div>
  </div>
  <div class="instagram-feed__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign fallback_asset_name = 'gas-gallery-' | append: forloop.index | append: '.svg'
        assign fallback_asset = fallback_asset_name | asset_url
      -%}
      <a
        class="instagram-feed__item"
        href="{{ block.settings.link | default: '#' }}"
        {% if block.settings.link != blank %}
          target="_blank" rel="noopener noreferrer"
        {% endif %}
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '300, 550, 750, 1100, 1500' }}
        {%- else -%}
          <img src="{{ fallback_asset }}" alt="Get Any Scent gallery artwork {{ forloop.index }}" width="1200" height="1200" loading="lazy">
        {%- endif -%}
        <span class="instagram-feed__overlay">FOLLOW</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FOLLOW THE WORLD OF @GETANYSCENT"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
