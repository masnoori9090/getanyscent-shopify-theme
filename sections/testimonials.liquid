{%- style -%}
  #shopify-section-{{ section.id }} .testimonials {
    padding: 8rem 0;
    background: #ede9e0;
  }

  #shopify-section-{{ section.id }} .testimonials__intro {
    margin-bottom: 3.2rem;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .testimonials__subheading {
    color: rgba(0, 0, 0, 0.58);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .testimonials__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_least: 1 | at_most: 3 }}, minmax(0, 1fr));
    gap: 2rem;
  }

  #shopify-section-{{ section.id }} .testimonial-card {
    padding: 3rem;
    border: 1px solid rgba(142, 134, 106, 0.3);
    background: rgba(245, 242, 237, 0.8);
  }

  #shopify-section-{{ section.id }} .testimonial-card__rating {
    color: #8e866a;
    letter-spacing: 0.2em;
  }

  #shopify-section-{{ section.id }} .testimonial-card blockquote {
    margin: 1.8rem 0;
    font-family: var(--font-heading-family);
    font-size: clamp(2.2rem, 3vw, 3rem);
    line-height: 1.24;
  }

  #shopify-section-{{ section.id }} .testimonial-card__meta {
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 1.1rem;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="testimonials reveal">
  <div class="page-width">
    <div class="testimonials__intro">
      <h2 class="h1">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="testimonials__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <article class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span>{% if i <= block.settings.rating %}&#9733;{% else %}&#9734;{% endif %}</span>
            {%- endfor -%}
          </div>
          <blockquote>{{ block.settings.quote }}</blockquote>
          <p class="testimonial-card__meta">
            {{ block.settings.name }}
            {%- if block.settings.location != blank -%}
              / {{ block.settings.location }}
            {%- endif -%}
          </p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NOTES FROM OUR CLIENTS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "For collectors, gift seekers, and fragrance devotees"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Aisha K."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Dubai"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Beautifully packaged, thoughtfully curated, and unlike anything I find in standard retail."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
