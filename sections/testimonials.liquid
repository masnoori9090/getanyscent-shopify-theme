{%- liquid
  assign testimonials_definition = blank
  assign testimonials_count = section.blocks.size
  if section.settings.metaobject_definition_handle != blank and metaobjects[section.settings.metaobject_definition_handle] != blank
    assign testimonials_definition = metaobjects[section.settings.metaobject_definition_handle]
    assign testimonials_count = testimonials_definition.values_count | at_most: section.settings.metaobject_limit
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .testimonials {
    padding: 8rem 0;
    background: var(--gradient-background);
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .testimonials__intro {
    margin-bottom: 3.2rem;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .testimonials__subheading {
    color: rgba(var(--color-foreground), 0.58);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .testimonials__grid {
    display: grid;
    grid-template-columns: repeat({{ testimonials_count | at_least: 1 | at_most: 3 }}, minmax(0, 1fr));
    gap: 2rem;
  }

  #shopify-section-{{ section.id }} .testimonial-card {
    padding: 3rem;
    border: 1px solid rgba(var(--color-foreground), 0.16);
    background: rgba(var(--color-foreground), 0.04);
  }

  #shopify-section-{{ section.id }} .testimonial-card__rating {
    color: rgb(var(--color-link));
    letter-spacing: 0.2em;
  }

  #shopify-section-{{ section.id }} .testimonial-card__avatar {
    width: 5.6rem;
    height: 5.6rem;
    margin-bottom: 1.6rem;
    overflow: hidden;
    border: 1px solid rgba(var(--color-foreground), 0.16);
  }

  #shopify-section-{{ section.id }} .testimonial-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .testimonial-card blockquote {
    margin: 1.8rem 0;
    font-family: var(--font-heading-family);
    font-size: clamp(2.2rem, 3vw, 3rem);
    line-height: 1.24;
  }

  #shopify-section-{{ section.id }} .testimonial-card__meta {
    color: rgba(var(--color-foreground), 0.72);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 1.1rem;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="testimonials getanyscent-section color-{{ section.settings.color_scheme }} gradient reveal">
  <div class="page-width">
    <div class="testimonials__intro">
      <h2 class="h1">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="testimonials__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="testimonials__grid">
      {%- if testimonials_definition != blank and testimonials_definition.values_count > 0 -%}
        {%- for entry in testimonials_definition.values limit: section.settings.metaobject_limit -%}
          {%- assign rating_value = entry.rating.value | default: 5 | plus: 0 -%}
          <article class="testimonial-card">
            {%- if entry.image.value != blank -%}
              <div class="testimonial-card__avatar">
                {{ entry.image.value | image_url: width: 220 | image_tag: loading: 'lazy', widths: '80, 120, 160, 220' }}
              </div>
            {%- endif -%}
            <div class="testimonial-card__rating" aria-label="{{ rating_value }} out of 5 stars">
              {%- for i in (1..5) -%}
                <span>{% if i <= rating_value %}&#9733;{% else %}&#9734;{% endif %}</span>
              {%- endfor -%}
            </div>
            <blockquote>{{ entry.quote.value }}</blockquote>
            <p class="testimonial-card__meta">
              {{ entry.name.value }}
              {%- if entry.location.value != blank -%}
                / {{ entry.location.value }}
              {%- endif -%}
            </p>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <article class="testimonial-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="testimonial-card__avatar">
                {{ block.settings.image | image_url: width: 220 | image_tag: loading: 'lazy', widths: '80, 120, 160, 220' }}
              </div>
            {%- endif -%}
            <div class="testimonial-card__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                <span>{% if i <= block.settings.rating %}&#9733;{% else %}&#9734;{% endif %}</span>
              {%- endfor -%}
            </div>
            <blockquote>{{ block.settings.quote }}</blockquote>
            <p class="testimonial-card__meta">
              {{ block.settings.name }}
              {%- if block.settings.location != blank -%}
                / {{ block.settings.location }}
              {%- endif -%}
            </p>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NOTES FROM OUR CLIENTS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "For collectors, gift seekers, and fragrance devotees"
    },
    {
      "type": "text",
      "id": "metaobject_definition_handle",
      "label": "Metaobject definition handle",
      "info": "Optional. Example: testimonials. Expected fields: image, name, location, quote, rating."
    },
    {
      "type": "range",
      "id": "metaobject_limit",
      "label": "Metaobject items to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Aisha K."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Dubai"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Beautifully packaged, thoughtfully curated, and unlike anything I find in standard retail."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
