<section class="getanyscent-value-bar reveal">
  <div class="getanyscent-shell">
    <div class="getanyscent-value-bar__grid">
      {%- for block in section.blocks -%}
        <div class="getanyscent-value-bar__item" {{ block.shopify_attributes }}>
          <p class="getanyscent-value-bar__title">{{ block.settings.title }}</p>
          {%- if block.settings.text != blank -%}
            <p class="getanyscent-value-bar__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Value Bar",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Free GCC shipping" },
        { "type": "text", "id": "text", "label": "Text", "default": "Fast, tracked dispatch on qualifying orders." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Get Any Scent Value Bar",
      "blocks": [
        { "type": "value" },
        { "type": "value" },
        { "type": "value" },
        { "type": "value" }
      ]
    }
  ]
}
{% endschema %}
