<section class="getanyscent-section getanyscent-hero color-{{ section.settings.color_scheme }}">
  <div class="getanyscent-hero__grid">
    <div class="getanyscent-hero__media">
      {% if section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 2200
          | image_tag:
            widths: '750, 1100, 1500, 1800, 2200',
            class: 'getanyscent-hero__image',
            alt: section.settings.heading,
            loading: 'eager'
        }}
      {% endif %}
      <div class="getanyscent-hero__mist"></div>
      <div class="getanyscent-hero__bottle" aria-hidden="true"></div>
    </div>

    <div class="getanyscent-hero__content">
      <div class="getanyscent-hero__content-inner">
        {% if section.settings.overline != blank %}
          <p class="getanyscent-eyebrow">{{ section.settings.overline }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="getanyscent-heading">{{ section.settings.heading | newline_to_br }}</h1>
        {% endif %}

        {% if section.settings.copy != blank %}
          <div class="getanyscent-copy rte">{{ section.settings.copy }}</div>
        {% endif %}

        {% if section.settings.primary_label != blank or section.settings.secondary_label != blank %}
          <div class="getanyscent-button-row">
            {% if section.settings.primary_label != blank %}
              <a
                class="getanyscent-button"
                {% if section.settings.primary_link != blank %}
                  href="{{ section.settings.primary_link }}"
                {% else %}
                  role="link"
                  aria-disabled="true"
                {% endif %}
              >
                {{ section.settings.primary_label }}
              </a>
            {% endif %}

            {% if section.settings.secondary_label != blank %}
              <a
                class="getanyscent-button getanyscent-button--solid"
                {% if section.settings.secondary_link != blank %}
                  href="{{ section.settings.secondary_link }}"
                {% else %}
                  role="link"
                  aria-disabled="true"
                {% endif %}
              >
                {{ section.settings.secondary_label }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {% if section.settings.scroll_label != blank %}
    <div class="getanyscent-hero__scroll">{{ section.settings.scroll_label }}</div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Get Any Scent Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "New Collection"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "THE ART\nOF SCENT"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy",
      "default": "<p>Rare fragrances sourced from the world's finest perfumers and presented with the calm confidence of a luxury editorial store.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Shop Bestsellers"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "Scroll label",
      "default": "Scroll"
    }
  ],
  "presets": [
    {
      "name": "Get Any Scent Hero"
    }
  ]
}
{% endschema %}
