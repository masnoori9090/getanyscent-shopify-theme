{%- assign hero_asset = 'gas-ref-hero-bottle.jpg' | asset_url -%}
{%- liquid
  assign hero_target = section.settings.button_link
  if hero_target == blank and section.settings.button_collection != blank
    assign hero_target = section.settings.button_collection.url
  endif
  if hero_target == blank and section.settings.button_product != blank
    assign hero_target = section.settings.button_product.url
  endif
  if hero_target == blank
    assign hero_target = routes.all_products_collection_url
  endif
-%}

<section class="getanyscent-hero getanyscent-section color-{{ section.settings.color_scheme }} gradient reveal">
  <div class="getanyscent-shell getanyscent-hero__shell">
    <div class="getanyscent-hero__grid">
      <div class="getanyscent-hero__feature">
        <div class="getanyscent-hero__media">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 2200
              | image_tag:
                loading: 'eager',
                widths: '750, 990, 1200, 1600, 2000, 2200',
                fetchpriority: 'high'
            }}
          {%- else -%}
            <img src="{{ hero_asset }}" alt="Get Any Scent hero artwork" width="1600" height="2000" loading="eager">
          {%- endif -%}
          <div class="getanyscent-hero__mist"></div>
        </div>
        <div class="getanyscent-hero__content">
          <div class="getanyscent-hero__content-inner">
            {%- if section.settings.eyebrow != blank -%}
              <p class="getanyscent-hero__eyebrow">{{ section.settings.eyebrow }}</p>
            {%- endif -%}
            <h1 class="getanyscent-heading">{{ section.settings.heading }}</h1>
            {%- if section.settings.text != blank -%}
              <p class="getanyscent-copy">{{ section.settings.text }}</p>
            {%- endif -%}
            {%- if section.settings.button_label != blank -%}
              <div class="getanyscent-button-row">
                <a href="{{ hero_target }}" class="getanyscent-button getanyscent-button--solid">
                  {{ section.settings.button_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="getanyscent-hero__promos">
          {%- for block in section.blocks -%}
            {%- liquid
              assign promo_target = block.settings.link
              if promo_target == blank and block.settings.collection != blank
                assign promo_target = block.settings.collection.url
              endif
              if promo_target == blank and block.settings.product != blank
                assign promo_target = block.settings.product.url
              endif
              if promo_target == blank
                assign promo_target = hero_target
              endif

              case forloop.index
                when 1
                  assign fallback_asset = 'gas-ref-product-oud-royal.jpg' | asset_url
                when 2
                  assign fallback_asset = 'gas-ref-product-santal-dore.jpg' | asset_url
                else
                  assign fallback_asset = 'gas-ref-story-botanical.jpg' | asset_url
              endcase
            -%}
            <a href="{{ promo_target }}" class="getanyscent-hero__promo-card" {{ block.shopify_attributes }}>
              <div class="getanyscent-hero__promo-media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      widths: '360, 550, 720, 900, 1200'
                  }}
                {%- else -%}
                  <img src="{{ fallback_asset }}" alt="{{ block.settings.heading | escape }}" width="900" height="1100" loading="lazy">
                {%- endif -%}
              </div>
              <div class="getanyscent-hero__promo-content">
                {%- if block.settings.eyebrow != blank -%}
                  <p class="getanyscent-hero__promo-eyebrow">{{ block.settings.eyebrow }}</p>
                {%- endif -%}
                <h3>{{ block.settings.heading }}</h3>
                {%- if block.settings.text != blank -%}
                  <p>{{ block.settings.text }}</p>
                {%- endif -%}
                {%- if block.settings.button_label != blank -%}
                  <span class="getanyscent-hero__promo-cta">{{ block.settings.button_label }}</span>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Hero",
  "tag": "section",
  "class": "section",
  "max_blocks": 2,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-4" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New arrivals" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "NEW SEASON FRAGRANCE EDIT" },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Launch your next signature scent with campaign-led storytelling, featured collections, and fast product discovery."
    },
    { "type": "collection", "id": "button_collection", "label": "Button collection source" },
    { "type": "product", "id": "button_product", "label": "Button product source" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "SHOP THE DROP" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "promo_card",
      "name": "Promo card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Limited release" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Weekend promotion" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Highlight a collection, seasonal edit, or limited drop." },
        { "type": "collection", "id": "collection", "label": "Collection source" },
        { "type": "product", "id": "product", "label": "Product source" },
        { "type": "url", "id": "link", "label": "Link override" },
        { "type": "text", "id": "button_label", "label": "CTA label", "default": "Shop now" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Get Any Scent Hero",
      "blocks": [
        { "type": "promo_card" },
        { "type": "promo_card" }
      ]
    }
  ]
}
{% endschema %}
