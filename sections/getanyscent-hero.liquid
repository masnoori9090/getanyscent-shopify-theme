{%- assign hero_asset = 'gas-ref-hero-bottle.jpg' | asset_url -%}

<section class="getanyscent-hero reveal">
  <div class="getanyscent-hero__grid">
    <div class="getanyscent-hero__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 2200
          | image_tag:
            loading: 'eager',
            widths: '750, 990, 1200, 1600, 2000, 2200',
            fetchpriority: 'high'
        }}
      {%- else -%}
        <img src="{{ hero_asset }}" alt="Get Any Scent hero artwork" width="1600" height="2000" loading="eager">
      {%- endif -%}
      <div class="getanyscent-hero__mist"></div>
    </div>
    <div class="getanyscent-hero__content">
      <div class="getanyscent-hero__content-inner">
        <p class="getanyscent-eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="getanyscent-heading">{{ section.settings.heading }}</h1>
        <p class="getanyscent-copy">{{ section.settings.text }}</p>
        {%- if section.settings.button_label != blank -%}
          <div class="getanyscent-button-row">
            <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="getanyscent-button">
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
  <div class="getanyscent-hero__scroll" aria-hidden="true"></div>
</section>

{% schema %}
{
  "name": "Get Any Scent Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "THE ART OF SCENT" },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Rare fragrances sourced from the world's finest perfumers."
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "EXPLORE COLLECTION" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Get Any Scent Hero" }]
}
{% endschema %}
