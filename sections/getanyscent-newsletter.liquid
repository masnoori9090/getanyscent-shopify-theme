<section class="getanyscent-newsletter getanyscent-section color-{{ section.settings.color_scheme }} gradient reveal">
  <div class="page-width">
    <div class="getanyscent-newsletter__inner">
      <p class="getanyscent-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="getanyscent-heading">{{ section.settings.heading }}</h2>
      <p class="getanyscent-copy">{{ section.settings.text }}</p>
      {%- form 'customer', class: 'getanyscent-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          placeholder="{{ section.settings.placeholder }}"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >
        <button type="submit" class="getanyscent-button getanyscent-button--solid">{{ section.settings.button_label }}</button>
      {%- endform -%}
      {%- if form.posted_successfully? -%}
        <p class="newsletter-form__message newsletter-form__message--success">{{ section.settings.success_message }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-4" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay Connected" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "JOIN THE INNER CIRCLE" },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Be the first to discover new arrivals and exclusive offers."
    },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "SUBSCRIBE" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "WELCOME TO THE INNER CIRCLE" }
  ],
  "presets": [{ "name": "Get Any Scent Newsletter" }]
}
{% endschema %}
