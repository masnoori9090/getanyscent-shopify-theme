<section class="getanyscent-section getanyscent-newsletter">
  <div class="getanyscent-shell">
    <div class="getanyscent-newsletter__inner">
      {% if section.settings.eyebrow != blank %}
        <p class="getanyscent-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="getanyscent-heading">{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
      {% if section.settings.copy != blank %}
        <div class="getanyscent-copy rte">{{ section.settings.copy }}</div>
      {% endif %}

      {% form 'customer', class: 'getanyscent-newsletter__signup' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="getanyscent-newsletter__form">
          <input
            type="email"
            name="contact[email]"
            id="NewsletterForm--{{ section.id }}"
            value="{{ form.email }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            placeholder="{{ section.settings.placeholder }}"
            aria-label="{{ section.settings.placeholder }}"
            required
          >
          <button class="getanyscent-button getanyscent-button--solid" type="submit">
            {{ section.settings.button_label }}
          </button>
        </div>

        {% if form.errors %}
          <div class="form__message">{{ form.errors | default_errors }}</div>
        {% endif %}
        {% if form.posted_successfully? %}
          <div class="form__message">{{ section.settings.success_message }}</div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Newsletter",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Stay Connected"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Join the inner circle"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy",
      "default": "<p>Invite customers into your launch cadence, restock drops, and founder notes with a cleaner luxury newsletter block.</p>"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're on the list."
    }
  ],
  "presets": [
    {
      "name": "Get Any Scent Newsletter"
    }
  ]
}
{% endschema %}
