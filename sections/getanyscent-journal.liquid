<section class="getanyscent-journal getanyscent-section color-{{ section.settings.color_scheme }} gradient reveal">
  <div class="getanyscent-shell">
    {%- if section.settings.heading != blank -%}
      <div class="getanyscent-heading-stack">
        <div class="gold-divider"></div>
        <h2 class="getanyscent-heading">{{ section.settings.heading }}</h2>
        <div class="gold-divider"></div>
      </div>
    {%- endif -%}
    <div class="getanyscent-journal__grid">
      {%- liquid
        assign article_source = blank
        assign blog_secondary_limit = section.settings.articles_to_show | minus: 1
        if section.settings.blog != blank and section.settings.blog.articles_count > 0
          assign article_source = 'blog'
        elsif section.blocks.size > 0
          assign article_source = 'blocks'
        endif
        assign featured_block = section.blocks.first
      -%}
      {%- if article_source == 'blog' -%}
        {%- assign featured_article = section.settings.blog.articles.first -%}
        {%- if featured_article != blank -%}
          {%- assign featured_fallback_asset = 'gas-ref-journal-featured.jpg' | asset_url -%}
          {%- assign featured_category = featured_article.tags.first | default: section.settings.blog.title -%}
          <a href="{{ featured_article.url }}" class="getanyscent-journal__card getanyscent-journal__card--feature">
            {%- if featured_article.image != blank -%}
              {{ featured_article.image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '550, 720, 900, 1200, 1500, 1600' }}
            {%- else -%}
              <div class="getanyscent-journal__placeholder">
                <img src="{{ featured_fallback_asset }}" alt="{{ featured_article.title | escape }}" width="1600" height="1200" loading="lazy">
              </div>
            {%- endif -%}
            <div class="getanyscent-journal__content">
              <p class="getanyscent-journal__meta">{{ featured_category }} — {{ featured_article.published_at | date: '%B %Y' }}</p>
              <h3>{{ featured_article.title }}</h3>
              {%- if featured_article.excerpt != blank -%}
                <p class="getanyscent-journal__excerpt">{{ featured_article.excerpt | strip_html }}</p>
              {%- elsif featured_article.content != blank -%}
                <p class="getanyscent-journal__excerpt">{{ featured_article.content | strip_html | truncate: 140 }}</p>
              {%- endif -%}
            </div>
          </a>
        {%- endif -%}
      {%- elsif featured_block != blank -%}
        {%- assign featured_fallback_asset = 'gas-ref-journal-featured.jpg' | asset_url -%}
        <a href="{{ featured_block.settings.link | default: '#' }}" class="getanyscent-journal__card getanyscent-journal__card--feature">
          {%- if featured_block.settings.image != blank -%}
            {{
              featured_block.settings.image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                widths: '550, 720, 900, 1200, 1500, 1600'
            }}
          {%- else -%}
            <div class="getanyscent-journal__placeholder">
              <img
                src="{{ featured_fallback_asset }}"
                alt="{{ featured_block.settings.title | escape }}"
                width="1600"
                height="1200"
                loading="lazy"
              >
            </div>
          {%- endif -%}
          <div class="getanyscent-journal__content">
            <p class="getanyscent-journal__meta">{{ featured_block.settings.category }} — {{ featured_block.settings.date }}</p>
            <h3>{{ featured_block.settings.title }}</h3>
            {%- if featured_block.settings.excerpt != blank -%}
              <p class="getanyscent-journal__excerpt">{{ featured_block.settings.excerpt }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endif -%}
      <div class="getanyscent-journal__stack">
        {%- if article_source == 'blog' -%}
          {%- for article in section.settings.blog.articles offset: 1 limit: blog_secondary_limit -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                {%- assign fallback_asset = 'gas-ref-journal-2.jpg' | asset_url -%}
              {%- else -%}
                {%- assign fallback_asset = 'gas-ref-journal-3.jpg' | asset_url -%}
            {%- endcase -%}
            {%- assign article_category = article.tags.first | default: section.settings.blog.title -%}
            <a href="{{ article.url }}" class="getanyscent-journal__card">
              {%- if article.image != blank -%}
                {{ article.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400, 550, 750, 1100, 1200' }}
              {%- else -%}
                <div class="getanyscent-journal__placeholder">
                  <img src="{{ fallback_asset }}" alt="{{ article.title | escape }}" width="1200" height="900" loading="lazy">
                </div>
              {%- endif -%}
              <div class="getanyscent-journal__content">
                <p class="getanyscent-journal__meta">{{ article_category }} — {{ article.published_at | date: '%B %Y' }}</p>
                <h3>{{ article.title }}</h3>
                {%- if article.excerpt != blank -%}
                  <p class="getanyscent-journal__excerpt">{{ article.excerpt | strip_html }}</p>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks offset: 1 -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                {%- assign fallback_asset = 'gas-ref-journal-2.jpg' | asset_url -%}
              {%- else -%}
                {%- assign fallback_asset = 'gas-ref-journal-3.jpg' | asset_url -%}
            {%- endcase -%}
            <a href="{{ block.settings.link | default: '#' }}" class="getanyscent-journal__card">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  widths: '400, 550, 750, 1100, 1200'
              }}
            {%- else -%}
              <div class="getanyscent-journal__placeholder">
                <img
                  src="{{ fallback_asset }}"
                  alt="{{ block.settings.title | escape }}"
                  width="1200"
                  height="900"
                  loading="lazy"
                >
              </div>
            {%- endif -%}
            <div class="getanyscent-journal__content">
              <p class="getanyscent-journal__meta">{{ block.settings.category }} — {{ block.settings.date }}</p>
              <h3>{{ block.settings.title }}</h3>
              {%- if block.settings.excerpt != blank -%}
                <p class="getanyscent-journal__excerpt">{{ block.settings.excerpt }}</p>
              {%- endif -%}
            </div>
          </a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Journal",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "THE JOURNAL" },
    { "type": "blog", "id": "blog", "label": "Blog source" },
    { "type": "range", "id": "articles_to_show", "label": "Articles to show", "min": 2, "max": 3, "step": 1, "default": 3 }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "category", "label": "Category", "default": "Journal" },
        { "type": "text", "id": "date", "label": "Date", "default": "March 2026" },
        { "type": "text", "id": "title", "label": "Title", "default": "How to Build a Fragrance Wardrobe That Lasts Beyond the Season" },
        { "type": "textarea", "id": "excerpt", "label": "Excerpt", "default": "A considered approach to daytime freshness, evening depth, and signatures that leave a refined trail." },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Get Any Scent Journal",
      "blocks": [{ "type": "article" }, { "type": "article" }, { "type": "article" }]
    }
  ]
}
{% endschema %}
