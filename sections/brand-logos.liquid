{%- liquid
  assign logos_definition = blank
  assign logos_count = section.blocks.size
  if section.settings.metaobject_definition_handle != blank and metaobjects[section.settings.metaobject_definition_handle] != blank
    assign logos_definition = metaobjects[section.settings.metaobject_definition_handle]
    assign logos_count = logos_definition.values_count | at_most: section.settings.metaobject_limit
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .brand-logos {
    padding: 6rem 0;
  }

  #shopify-section-{{ section.id }} .brand-logos__grid {
    display: grid;
    grid-template-columns: repeat({{ logos_count | at_least: 2 | at_most: 6 }}, minmax(0, 1fr));
    gap: 1.6rem;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .brand-logos__item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 9rem;
    padding: 2rem;
    border: 1px solid rgba(var(--color-foreground), 0.14);
    background: rgba(var(--color-foreground), 0.04);
    filter: grayscale(1);
    opacity: 0.72;
    transition: filter 0.3s ease, opacity 0.3s ease, transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .brand-logos__item:hover {
    filter: grayscale(0);
    opacity: 1;
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .brand-logos__item img,
  #shopify-section-{{ section.id }} .brand-logos__item .placeholder-svg {
    max-width: 100%;
    max-height: 3.6rem;
    width: auto;
    height: auto;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .brand-logos__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

<section class="brand-logos getanyscent-section color-{{ section.settings.color_scheme }} gradient reveal">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="center" style="margin-bottom: 2.4rem;">
        <h2 class="h2">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="brand-logos__grid">
      {%- if logos_definition != blank and logos_definition.values_count > 0 -%}
        {%- for entry in logos_definition.values limit: section.settings.metaobject_limit -%}
          {%- assign logo_link = entry.link.value -%}
          {%- assign logo_name = entry.name.value | default: shop.name -%}
          {%- if logo_link != blank -%}
            <a href="{{ logo_link }}" class="brand-logos__item" aria-label="{{ logo_name | escape }}">
          {%- else -%}
            <div class="brand-logos__item">
          {%- endif -%}
            {%- if entry.logo.value != blank -%}
              {{ entry.logo.value | image_url: width: 500 | image_tag: loading: 'lazy', widths: '150, 220, 300, 500', alt: logo_name }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          {%- if logo_link != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="brand-logos__item" {{ block.shopify_attributes }}>
          {%- else -%}
            <div class="brand-logos__item" {{ block.shopify_attributes }}>
          {%- endif -%}
            {%- if block.settings.logo != blank -%}
              {{ block.settings.logo | image_url: width: 500 | image_tag: loading: 'lazy', widths: '150, 220, 300, 500' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Logos",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "paragraph",
      "content": "Use this section for featured houses, press mentions, retail partners, or trusted payment and delivery brands."
    },
    {
      "type": "text",
      "id": "metaobject_definition_handle",
      "label": "Metaobject definition handle",
      "info": "Optional. Example: brand_logos. Expected fields: logo, link, name."
    },
    {
      "type": "range",
      "id": "metaobject_limit",
      "label": "Metaobject items to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
