<section class="getanyscent-section getanyscent-marquee">
  <div class="getanyscent-marquee__track" aria-label="{{ section.settings.accessibility_label | escape }}">
    {% for repeat in (1..2) %}
      {% for block in section.blocks %}
        {% if repeat == 1 %}
          <span class="getanyscent-marquee__item" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </span>
        {% else %}
          <span class="getanyscent-marquee__item">{{ block.settings.text }}</span>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Marquee",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "Brand highlights"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Curated selections"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Get Any Scent Marquee",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "text": "Curated selections"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "Rare fragrance houses"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "Luxury discovery"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "Worldwide shipping"
          }
        }
      ]
    }
  ]
}
{% endschema %}
