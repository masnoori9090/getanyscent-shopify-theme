<section class="getanyscent-marquee getanyscent-section color-{{ section.settings.color_scheme }} gradient reveal">
  <div class="getanyscent-marquee__track">
    {%- for i in (1..8) -%}
      <span class="getanyscent-marquee__item">{{ section.settings.text }}</span>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "NICHE FRAGRANCES • ARTISAN CRAFTED • WORLDWIDE SHIPPING • SINCE 2024"
    }
  ],
  "presets": [{ "name": "Get Any Scent Marquee" }]
}
{% endschema %}
