{% liquid
  assign collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
%}

<section class="getanyscent-section getanyscent-featured">
  <div class="getanyscent-shell">
    <div class="getanyscent-heading-stack">
      {% if section.settings.eyebrow != blank %}
        <p class="getanyscent-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="getanyscent-heading">{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
      {% if section.settings.copy != blank %}
        <div class="getanyscent-copy rte">{{ section.settings.copy }}</div>
      {% endif %}
    </div>

    <div class="getanyscent-featured__grid">
      {% if collection != blank and collection.products.size > 0 %}
        {% for product in collection.products limit: products_to_show %}
          <a
            href="{{ product.url }}"
            class="getanyscent-featured__card{% if forloop.first %} getanyscent-featured__card--featured{% endif %}"
          >
            {% if product.featured_image != blank %}
              <div class="getanyscent-featured__image">
                {{
                  product.featured_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '360, 533, 720, 940, 1200',
                    alt: product.title,
                    loading: 'lazy'
                }}
              </div>
            {% else %}
              <div class="getanyscent-featured__placeholder"></div>
            {% endif %}

            <div class="getanyscent-featured__content">
              {% if product.vendor != blank and section.settings.show_vendor %}
                <div class="getanyscent-featured__meta">{{ product.vendor }}</div>
              {% endif %}
              <h3 class="getanyscent-featured__title">{{ product.title }}</h3>
              <div class="getanyscent-featured__price">
                {% if product.compare_at_price > product.price %}
                  <span>{{ product.price | money }}</span>
                {% else %}
                  <span>{{ product.price | money }}</span>
                {% endif %}
              </div>
              <div class="getanyscent-featured__cta">{{ section.settings.card_cta }}</div>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <div class="getanyscent-featured__card{% if forloop.first %} getanyscent-featured__card--featured{% endif %}">
            <div class="getanyscent-featured__placeholder"></div>
            <div class="getanyscent-featured__content">
              <div class="getanyscent-featured__meta">Placeholder</div>
              <h3 class="getanyscent-featured__title">Add a collection</h3>
              <div class="getanyscent-featured__price">{{ 12000 | money }}</div>
              <div class="getanyscent-featured__cta">{{ section.settings.card_cta }}</div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.button_label != blank and collection != blank %}
      <div style="margin-top: 3rem; text-align: center;">
        <a class="getanyscent-button" href="{{ collection.url }}">{{ section.settings.button_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Collection",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated selections"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Discover the house signatures"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy",
      "default": "<p>Use this section for featured arrivals, bestsellers, or any tightly edited capsule collection.</p>"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 3,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "text",
      "id": "card_cta",
      "label": "Card CTA",
      "default": "Shop now"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Bottom button label",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "Get Any Scent Collection"
    }
  ]
}
{% endschema %}
