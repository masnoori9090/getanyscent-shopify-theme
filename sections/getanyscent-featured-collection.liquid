{%- liquid
  assign featured_collection = section.settings.collection
  assign collection_url = section.settings.view_all_link
  if collection_url == blank
    assign collection_url = featured_collection.url | default: routes.all_products_collection_url
  endif
  assign item_limit = section.settings.products_to_show
-%}

<section class="getanyscent-featured reveal" id="collection">
  <div class="getanyscent-shell">
    <div class="getanyscent-heading-stack">
      <div class="gold-divider"></div>
      <h2 class="getanyscent-heading">{{ section.settings.heading }}</h2>
      <div class="gold-divider"></div>
    </div>
    <div class="getanyscent-featured__grid">
      {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
        {%- for product in featured_collection.products limit: item_limit -%}
          <a href="{{ product.url }}" class="getanyscent-featured__card{% if forloop.first %} getanyscent-featured__card--featured{% endif %}">
            <div class="getanyscent-featured__image">
              {%- if product.featured_media != blank -%}
                {{
                  product.featured_media
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '400, 550, 750, 1100, 1200'
                }}
              {%- else -%}
                <div class="getanyscent-featured__placeholder"></div>
              {%- endif -%}
            </div>
            <div class="getanyscent-featured__content">
              {%- if section.settings.show_vendor and product.vendor != blank -%}
                <p class="getanyscent-featured__meta">{{ product.vendor }}</p>
              {%- endif -%}
              <h3 class="getanyscent-featured__title">{{ product.title }}</h3>
              {%- if section.settings.show_price -%}
                <p class="getanyscent-featured__price">{{ product.price | money }}</p>
              {%- endif -%}
              <span class="getanyscent-featured__cta">{{ section.settings.card_cta_label }}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- elsif section.blocks.size > 0 -%}
        {%- for block in section.blocks limit: item_limit -%}
          {%- liquid
            assign manual_url = block.settings.link
            assign manual_title = block.settings.title
            assign manual_vendor = block.settings.vendor
            assign manual_price = block.settings.price
            assign manual_image = block.settings.image
            case forloop.index
              when 1
                assign fallback_asset = 'gas-ref-product-oud-royal.jpg' | asset_url
              when 2
                assign fallback_asset = 'gas-ref-product-noir-botanica.jpg' | asset_url
              when 3
                assign fallback_asset = 'gas-ref-product-santal-dore.jpg' | asset_url
              when 4
                assign fallback_asset = 'gas-ref-product-ambre-sacre.jpg' | asset_url
              when 5
                assign fallback_asset = 'gas-ref-product-vert-sauvage.jpg' | asset_url
              else
                assign fallback_asset = 'gas-ref-product-cuir-de-nuit.jpg' | asset_url
            endcase
            if block.settings.product != blank
              assign manual_url = block.settings.product.url
              if manual_title == blank
                assign manual_title = block.settings.product.title
              endif
              if manual_vendor == blank
                assign manual_vendor = block.settings.product.vendor
              endif
              if manual_price == blank
                assign manual_price = block.settings.product.price | money
              endif
              if manual_image == blank and block.settings.product.featured_media != blank
                assign manual_image = block.settings.product.featured_media.preview_image
              endif
            endif
            if manual_url == blank
              assign manual_url = collection_url
            endif
          -%}
          <a href="{{ manual_url }}" class="getanyscent-featured__card{% if forloop.first %} getanyscent-featured__card--featured{% endif %}" {{ block.shopify_attributes }}>
            <div class="getanyscent-featured__image">
              {%- if manual_image != blank -%}
                {{ manual_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400, 550, 750, 1100, 1200' }}
              {%- else -%}
                <div class="getanyscent-featured__placeholder">
                  <img src="{{ fallback_asset }}" alt="{{ manual_title | escape }}" width="1200" height="1600" loading="lazy">
                </div>
              {%- endif -%}
            </div>
            <div class="getanyscent-featured__content">
              {%- if section.settings.show_vendor and manual_vendor != blank -%}
                <p class="getanyscent-featured__meta">{{ manual_vendor }}</p>
              {%- endif -%}
              <h3 class="getanyscent-featured__title">{{ manual_title }}</h3>
              {%- if section.settings.show_price and manual_price != blank -%}
                <p class="getanyscent-featured__price">{{ manual_price }}</p>
              {%- endif -%}
              <span class="getanyscent-featured__cta">{{ section.settings.card_cta_label }}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- assign fallback_asset = 'gas-ref-product-oud-royal.jpg' | asset_url -%}
              {%- assign fallback_title = 'Oud Royal' -%}
              {%- assign fallback_meta = 'Get Any Scent' -%}
              {%- assign fallback_price = '$285' -%}
            {%- when 2 -%}
              {%- assign fallback_asset = 'gas-ref-product-noir-botanica.jpg' | asset_url -%}
              {%- assign fallback_title = 'Noir Botanica' -%}
              {%- assign fallback_meta = 'Get Any Scent' -%}
              {%- assign fallback_price = '$245' -%}
            {%- else -%}
              {%- assign fallback_asset = 'gas-ref-product-santal-dore.jpg' | asset_url -%}
              {%- assign fallback_title = 'Santal Doré' -%}
              {%- assign fallback_meta = 'Get Any Scent' -%}
              {%- assign fallback_price = '$310' -%}
          {%- endcase -%}
          <a href="{{ collection_url }}" class="getanyscent-featured__card{% if forloop.first %} getanyscent-featured__card--featured{% endif %}">
            <div class="getanyscent-featured__placeholder">
              <img src="{{ fallback_asset }}" alt="{{ fallback_title }}" width="1200" height="1600" loading="lazy">
            </div>
            <div class="getanyscent-featured__content">
              {%- if section.settings.show_vendor -%}
                <p class="getanyscent-featured__meta">{{ fallback_meta }}</p>
              {%- endif -%}
              <h3 class="getanyscent-featured__title">{{ fallback_title }}</h3>
              {%- if section.settings.show_price -%}
                <p class="getanyscent-featured__price">{{ fallback_price }}</p>
              {%- endif -%}
              <span class="getanyscent-featured__cta">{{ section.settings.card_cta_label }}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="center" style="margin-top: 4rem;">
      <a href="{{ collection_url }}" class="gold-underline-link">{{ section.settings.view_all_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Featured",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "CURATED SELECTIONS" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Items to show", "min": 3, "max": 6, "step": 1, "default": 3 },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": true },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },
    { "type": "text", "id": "card_cta_label", "label": "Card CTA label", "default": "Shop Now" },
    { "type": "url", "id": "view_all_link", "label": "View all link override" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "VIEW ALL" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Manual card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product source" },
        { "type": "image_picker", "id": "image", "label": "Override image" },
        { "type": "text", "id": "vendor", "label": "Vendor override" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "text", "id": "price", "label": "Price override" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "presets": [{ "name": "Get Any Scent Featured" }]
}
{% endschema %}
