{%- assign fallback_asset = 'gas-ref-story-botanical.jpg' | asset_url -%}

<section class="getanyscent-page-hero reveal{% if section.settings.layout == 'split' %} getanyscent-page-hero--split{% endif %}">
  <div class="getanyscent-page-hero__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2200
        | image_tag:
          loading: 'eager',
          widths: '750, 990, 1200, 1600, 2000, 2200',
          fetchpriority: 'high'
      }}
    {%- else -%}
      <img src="{{ fallback_asset }}" alt="{{ section.settings.heading | escape }}" width="1800" height="2200" loading="eager">
    {%- endif -%}
  </div>
  <div class="getanyscent-page-hero__overlay"></div>
  <div class="getanyscent-shell getanyscent-page-hero__shell">
    <div class="getanyscent-page-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="getanyscent-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="getanyscent-heading">{{ section.settings.heading }}</h1>
      {%- if section.settings.text != blank -%}
        <div class="getanyscent-copy rte">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="getanyscent-button-row">
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="getanyscent-button">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Get Any Scent Page Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "full",
      "options": [
        { "value": "full", "label": "Full overlay" },
        { "value": "split", "label": "Split content panel" }
      ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About Get Any Scent" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "CURATED FRAGRANCES FOR THE DISCERNING" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>A luxury destination for rare perfumes, quiet signatures, and the stories behind every bottle.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "SHOP COLLECTION" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Get Any Scent Page Hero" }]
}
{% endschema %}
