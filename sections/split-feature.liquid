{%- style -%}
  #shopify-section-{{ section.id }} .split-feature {
    padding: 8rem 0;
  }

  #shopify-section-{{ section.id }} .split-feature__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: 64rem;
  }

  #shopify-section-{{ section.id }} .split-feature__media {
    min-height: 42rem;
  }

  #shopify-section-{{ section.id }} .split-feature__media img,
  #shopify-section-{{ section.id }} .split-feature__media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .split-feature__content {
    display: flex;
    align-items: center;
    background: {{ section.settings.panel_color }};
    color: {{ section.settings.text_color }};
    padding: 6rem;
  }

  #shopify-section-{{ section.id }} .split-feature__eyebrow {
    margin-bottom: 1.6rem;
    color: rgba(245, 242, 237, 0.75);
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .split-feature__heading {
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .split-feature__text {
    margin-top: 2rem;
    color: color-mix(in srgb, {{ section.settings.text_color }} 76%, transparent);
    line-height: 1.8;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .split-feature__grid {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .split-feature__content {
      padding: 4rem 2.4rem;
    }
  }
{%- endstyle -%}

{%- assign split_fallback_asset = 'gas-story-art.svg' | asset_url -%}

<section class="split-feature reveal">
  <div class="page-width">
    <div class="split-feature__grid">
      {%- if section.settings.image_position == 'left' -%}
        <div class="split-feature__media">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '550, 720, 900, 1200, 1500, 1800' }}
          {%- else -%}
            <img src="{{ split_fallback_asset }}" alt="Get Any Scent editorial artwork" width="1400" height="1600" loading="lazy">
          {%- endif -%}
        </div>
      {%- endif -%}
      <div class="split-feature__content">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <p class="split-feature__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          <h2 class="split-feature__heading h1">{{ section.settings.heading }}</h2>
          <div class="split-feature__text rte">{{ section.settings.text }}</div>
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link }}" class="button button--secondary">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
      {%- if section.settings.image_position == 'right' -%}
        <div class="split-feature__media">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '550, 720, 900, 1200, 1500, 1800' }}
          {%- else -%}
            <img src="{{ split_fallback_asset }}" alt="Get Any Scent editorial artwork" width="1400" height="1600" loading="lazy">
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Split Feature",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ABOUT GET ANY SCENT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "RARE FINDS. QUIET LUXURY. LASTING IMPRESSION."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>We curate niche perfume houses, hard-to-source signatures, and refined gifting pieces for clients who want fragrance with character.</p><p>Every bottle in the collection is selected for depth, distinction, and the kind of trail people remember.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "READ OUR STORY"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "panel_color",
      "label": "Panel background",
      "default": "#132616"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F5F2ED"
    }
  ],
  "presets": [
    {
      "name": "Split Feature"
    }
  ]
}
{% endschema %}
